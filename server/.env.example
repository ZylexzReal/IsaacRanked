# VPS production server (.env on Oracle Cloud)
ISAAC_RANKED_DISABLE_LOG_BRIDGE=1
ISAAC_RANKED_HTTP_PORT=8766
ISAAC_RANKED_WS_PORT=8765
NODE_ENV=production

# Optional: override bridge directory on the VPS
# ISAAC_RANKED_BRIDGE_DIR=/var/lib/isaac-ranked-bridge

# --- Player PC bridge agent (do NOT use on VPS) ---
# ISAAC_RANKED_REMOTE_BRIDGE_URL=http://YOUR_VPS_PUBLIC_IP:8766/bridge
# ISAAC_RANKED_MOD_DIR=D:/SteamLibrary/steamapps/common/The Binding of Isaac Rebirth/mods/isaac-ranked
# ISAAC_RANKED_LOG_PATH=C:/Users/You/Documents/My Games/Binding of Isaac Repentance+/log.txt
