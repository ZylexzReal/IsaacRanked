{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "../server/src/bridge-agent.ts", "../server/src/bridge-inbox.ts", "../shared/**/*"],
  "exclude": ["node_modules", "dist"]
}
